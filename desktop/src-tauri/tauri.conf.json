{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Neural Junkie",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true
      },
      "shell": {
        "all": false,
        "open": true,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/nj-server",
            "sidecar": true
          }
        ]
      },
      "path": {
        "all": true
      },
      "protocol": {
        "asset": true,
        "assetScope": ["$HOME/**", "$TEMP/**", "/tmp/**", "/private/tmp/**"]
      },
      "fs": {
        "scope": ["$APPDATA/*", "$APPLOCALDATA/*"]
      },
      "window": {
        "all": true,
        "create": true,
        "center": true,
        "requestUserAttention": true,
        "setResizable": true,
        "setMaxSize": true,
        "setMinSize": true,
        "setSize": true,
        "setSkipTaskbar": true,
        "setDecorations": true,
        "setAlwaysOnTop": true,
        "setContentProtected": true,
        "setTitle": true,
        "maximize": true,
        "unmaximize": true,
        "minimize": true,
        "unminimize": true,
        "show": true,
        "hide": true,
        "close": true,
        "setFocus": true,
        "setIcon": true,
        "setFullscreen": true,
        "setCursorGrab": true,
        "setCursorVisible": true,
        "setCursorIcon": true,
        "setCursorPosition": true,
        "setIgnoreCursorEvents": true,
        "startDragging": true
      },
      "process": {
        "relaunch": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.camronwood.neuraljunkie",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/nj-server"
      ]
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "",
      "endpoints": [
        "https://github.com/camronwood/neural-junkie/releases/latest/download/update-{{target}}-{{arch}}.json"
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Neural Junkie",
        "width": 1000,
        "height": 700,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
