# Neural Junkie Environment Configuration

# AI Hub Configuration (Recommended)
USE_AI_HUB=true
AI_HUB_ENDPOINT=https://aihub.dispatchit.com/v1
ANTHROPIC_API_KEY=your_ai_hub_key_here

# Optional: Specify model (defaults to claude-sonnet)
# Options: claude-sonnet (better reasoning), claude-haiku (faster)
AI_HUB_MODEL=claude-sonnet

# For direct Anthropic API (if not using AI Hub)
# USE_AI_HUB=false
# ANTHROPIC_API_KEY=your_direct_anthropic_key_here

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost

# MCP Server Configuration
# Master switch to enable/disable MCP servers for all agents
ENABLE_MCP=true

# Individual agent MCP server enable flags
ENABLE_BACKEND_MCP=true
ENABLE_DEVOPS_MCP=true
ENABLE_DATABASE_MCP=true
ENABLE_FRONTEND_MCP=false
ENABLE_SECURITY_MCP=false

# MCP Server Ports (each agent gets its own port)
MCP_BACKEND_PORT=8081
MCP_DEVOPS_PORT=8082
MCP_DATABASE_PORT=8083
MCP_FRONTEND_PORT=8084
MCP_SECURITY_PORT=8085

# MCP Resource Server Configuration
# Enable MCP resource server for accessing exported agent knowledge
ENABLE_MCP_RESOURCES=true
MCP_RESOURCES_PORT=8086

# MCP Export Storage Configuration
# Directory for storing exported agent knowledge (defaults to ~/.neural-junkie/exports)
MCP_EXPORTS_DIR=~/.neural-junkie/exports

# CLI Agent - Cursor (Optional)
# Enables a Cursor CLI-backed agent in the chat.
# Requires the Cursor CLI to be installed: curl https://cursor.com/install -fsS | bash
# Get API key from your Cursor account settings.
CURSOR_API_KEY=your_cursor_api_key_here
CURSOR_WORK_DIR=/path/to/your/project

# Confluence Cloud Configuration (Optional)
# Required for Confluence documentation agents
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_DOMAIN=yourcompany.atlassian.net
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here


