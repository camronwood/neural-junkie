// handleListExports lists all exported agents
func (ch *CommandHandler) handleListExports(ctx context.Context, msg *protocol.Message) (*protocol.Message, error) {
	return ch.systemResponse(msg.Channel, "❌ MCP export functionality temporarily disabled"), nil

	var response strings.Builder
	response.WriteString("📦 **Exported Agents:**\n\n")

	for _, export := range exports {
		response.WriteString(fmt.Sprintf("• **%s** (%s)\n", export.Name, export.Type))
		response.WriteString(fmt.Sprintf("  - Resources: %d\n", export.ResourceCount))
// 		response.WriteString(fmt.Sprintf("  - Prompts: %d\n", export.PromptCount))
		response.WriteString(fmt.Sprintf("  - Size: %d bytes\n", export.FileSize))
		response.WriteString(fmt.Sprintf("  - Last Modified: %s\n", export.LastModified.Format("2006-01-02 15:04:05")))
		if export.Description != "" {
			response.WriteString(fmt.Sprintf("  - Description: %s\n", export.Description))
		}
		response.WriteString("\n")
	}

	response.WriteString("**Usage:**\n")
	response.WriteString("```\n/export-agent-mcp <agent-name>  # Export an agent\n")
	response.WriteString("/delete-export <agent-name>     # Delete an export\n")
	response.WriteString("/import-agent-mcp <path>        # Import from file\n```\n")

	return ch.systemResponse(msg.Channel, response.String()), nil
}

// handleDeleteExport deletes an exported agent
func (ch *CommandHandler) handleDeleteExport(ctx context.Context, msg *protocol.Message, parts []string) (*protocol.Message, error) {
	return ch.systemResponse(msg.Channel, "❌ MCP export functionality temporarily disabled"), nil

	agentName := parts[1]

	// Try to find the export to determine its type
	exports, err := ch.exportStorage.ListExports()
	if err != nil {
		return ch.systemResponse(msg.Channel, fmt.Sprintf("❌ Failed to list exports: %v", err)), nil
	}

// 	var agentType string
	for _, export := range exports {
		if export.Name == agentName {
			agentType = export.Type
			break
		}
	}

	if agentType == "" {
		return ch.systemResponse(msg.Channel, fmt.Sprintf("❌ Export '%s' not found. Use /list-exports to see available exports.", agentName)), nil
	}

	if err := ch.exportStorage.DeleteExport(agentName, agentType); err != nil {
		return ch.systemResponse(msg.Channel, fmt.Sprintf("❌ Failed to delete export: %v", err)), nil
	}

	return ch.systemResponse(msg.Channel, fmt.Sprintf("✅ Deleted export '%s' (%s)", agentName, agentType)), nil
// }

